# ── Backend ──────────────────────────────────────────────────────────────────
APP_ENV=development
PORT=8080

# Generate with: openssl rand -hex 64
JWT_SECRET=change-this-to-a-random-64-byte-hex-string-in-production

# PostgreSQL (see docker-compose.yml for local dev)
# Use sslmode=require in production
DATABASE_URL=postgres://user:password@localhost:5434/corekit?sslmode=disable

# Redis (optional — omit to disable)
REDIS_URL=redis://localhost:6380
REDIS_PASSWORD=

# S3-compatible storage (MinIO for local dev)
# IMPORTANT: In production, you MUST set S3_ACCESS_KEY and S3_SECRET_KEY.
# If S3_ENDPOINT is empty, the AWS SDK falls back to the default credential chain
# (env vars, ~/.aws/credentials, IAM role). This is NOT recommended for production.
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=corekit-data
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8080/api/auth/oauth/google/callback

# Frontend
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173

# CSRF protection (Double Submit Cookie pattern)
# Set to "false" if frontend and API are served from the same origin
# (e.g., reverse proxy on the same domain). Default: true.
CSRF_ENABLED=true

# SMTP (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_SKIP_VERIFY=false

# Introspection rate limit (requests per second)
INTROSPECTION_RATE_LIMIT=1000

# Service API key for service-to-service auth (optional)
SERVICE_API_KEY=
