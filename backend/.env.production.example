# ── Backend ──────────────────────────────────────────────────────────────────
APP_ENV=production
PORT=8080

# Generate with: openssl rand -hex 64
JWT_SECRET=change-this-to-a-random-64-byte-hex-string-in-production

# PostgreSQL — MUST use sslmode=require or sslmode=verify-full in production
DATABASE_URL=postgres://user:password@db:5432/corekit?sslmode=require

# Redis (optional — omit to disable, but rate limits fall back to per-instance)
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6380
REDIS_PASSWORD=

# S3-compatible storage — REQUIRED (server fails to start without)
S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=corekit-data
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=https://yourdomain.com/api/auth/oauth/google/callback

# Frontend
FRONTEND_URL=https://yourdomain.com
ALLOWED_ORIGINS=https://yourdomain.com

# CSRF protection (Double Submit Cookie pattern)
# Set to "true" for cross-origin deployments (frontend served from different domain).
# Set to "false" for same-origin deployments (reverse proxy serves both FE + API).
# Default: true. If using the provided Caddy reverse proxy, set to "false".
CSRF_ENABLED=false

# SMTP (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@yourdomain.com
SMTP_SKIP_VERIFY=false

# Service API key for service-to-service auth (optional)
SERVICE_API_KEY=

# Postgres (used by docker-compose.prod.yml)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
